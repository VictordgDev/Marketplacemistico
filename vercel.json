{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth.js?path=$path" },
    { "source": "/api/users/addresses/:id", "destination": "/api/users.js?path=addresses&id=$id" },
    { "source": "/api/users/:path", "destination": "/api/users.js?path=$path" },
    { "source": "/api/products/:id/publish", "destination": "/api/products.js?id=$id&path=publish" },
    { "source": "/api/products/:id", "destination": "/api/products.js?id=$id" },
    { "source": "/api/products", "destination": "/api/products.js" },
    { "source": "/api/sellers/me/products", "destination": "/api/sellers.js?path=me/products" },
    { "source": "/api/sellers/me/orders", "destination": "/api/sellers.js?path=me/orders" },
    { "source": "/api/sellers/me", "destination": "/api/sellers.js?path=me" },
    { "source": "/api/sellers/:id", "destination": "/api/sellers.js?id=$id" },
    { "source": "/api/orders/:id/status", "destination": "/api/orders.js?id=$id&path=status" },
    { "source": "/api/orders/:id", "destination": "/api/orders.js?id=$id" },
    { "source": "/api/orders", "destination": "/api/orders.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
